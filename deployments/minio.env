# MinIO Environment Configuration - AnyChat IM System
# Documentation: https://min.io/docs/minio/linux/reference/minio-server/settings.html

# ===== Authentication =====
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ===== Site Info =====
MINIO_SITE_NAME=anychat-minio
MINIO_SITE_REGION=us-east-1

# ===== Console =====
# Keep browser console enabled in dev environment
MINIO_BROWSER=on

# ===== Storage Class =====
# Single node dev mode, disable erasure coding redundancy check
MINIO_STORAGE_CLASS_STANDARD=EC:0

# ===== Audit Logging (recommended in production) =====
# MINIO_AUDIT_WEBHOOK_ENABLE_target1=on
# MINIO_AUDIT_WEBHOOK_ENDPOINT_target1=http://audit-collector:5000

# ===== Notifications (can integrate with NATS in production) =====
# MINIO_NOTIFY_NATS_ENABLE_anychat=on
# MINIO_NOTIFY_NATS_ADDRESS_anychat=nats:4222
# MINIO_NOTIFY_NATS_SUBJECT_anychat=minio.events